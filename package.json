{
  "name": "pixmicat-cf",
  "version": "1.0.0",
  "description": "Pixmicat! Imageboard System for Cloudflare Workers",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev --local --port 8787",
    "deploy": "wrangler deploy",
    "d1:create": "wrangler d1 create pixmicat-db",
    "d1:migrate": "wrangler d1 migrations apply pixmicat-db --remote",
    "d1:migrate:local": "wrangler d1 migrations apply pixmicat-db --local",
    "tail": "wrangler tail",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "imageboard",
    "pixmicat",
    "cloudflare",
    "workers"
  ],
  "author": "",
  "license": "Artistic-2.0",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "happy-dom": "^20.8.9",
    "spark-md5": "^3.0.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "wrangler": "^4.18.0"
  },
  "optionalDependencies": {
    "sharp": "^0.33.5"
  },
  "dependencies": {
    "itty-router": "^4.0.20"
  }
}
